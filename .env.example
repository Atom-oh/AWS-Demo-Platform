# AWS Demo Platform — local environment template.
# Copy to .env (gitignored) and fill in values. Production secrets live in AWS Secrets Manager.

# Application
APP_NAME=aws-demo-platform
APP_ENV=development

# AWS — for local Terraform / scripts
AWS_PROFILE=atomoh-main
AWS_REGION=ap-northeast-2

# Terraform backend (already set in each module's backend.tf, but kept here for visibility)
TF_BACKEND_BUCKET=multi-region-mall-terraform-state
TF_BACKEND_DDB_TABLE=multi-region-mall-terraform-locks

# ArgoCD CLI
ARGOCD_SERVER=argocd.atomai.click

# kube context (must point to mall-apne2-mgmt for hub ops)
KUBE_CONTEXT=mall-apne2-mgmt

# Claude Code Notifications (optional — Slack webhook)
# CLAUDE_NOTIFY_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Dashboard (Stage 3, not yet used)
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# GITHUB_APP_CLIENT_ID=
# DASHBOARD_DDB_TABLE=demo-platform-projects
