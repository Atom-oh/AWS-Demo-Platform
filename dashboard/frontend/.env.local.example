# Frontend build-time config (NEXT_PUBLIC_* are inlined at `next build`).
# Local dev against the dev-server: set AUTH_ENABLED=false to skip Cognito login.
# Prod image (CI build args): AUTH_ENABLED=true + the admin-dev.atomai.click URIs.

NEXT_PUBLIC_COGNITO_REGION=ap-northeast-2
NEXT_PUBLIC_COGNITO_DOMAIN=atomoh-demo-platform-dev.auth.ap-northeast-2.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=        # infra/cognito output app_client_id
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback   # prod: https://admin-dev.atomai.click/auth/callback
NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000                   # prod: https://admin-dev.atomai.click
NEXT_PUBLIC_AUTH_ENABLED=false        # prod: true

# Local dev only — where the Next rewrite proxies /api/* (the dev-server).
API_ORIGIN=http://localhost:8087
